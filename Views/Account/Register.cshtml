@model User

@{
    ViewData["Title"] = "Kayıt";
}

<div class="register-container">
    <h2>Kayıt Ol</h2>
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
    <form asp-action="Register" method="post" id="registerForm">
        <div class="form-group">
            <label asp-for="Name" class="form-label">Ad</label>
            <input asp-for="Name" class="form-control" required />
            <span asp-validation-for="Name" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Surname" class="form-label">Soyad</label>
            <input asp-for="Surname" class="form-control" required />
            <span asp-validation-for="Surname" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Age" class="form-label">Yaş</label>
            <input asp-for="Age" type="number" class="form-control" required min="18" />
            <span asp-validation-for="Age" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Email" class="form-label">E-posta</label>
            <input asp-for="Email" type="email" class="form-control" required />
            <span asp-validation-for="Email" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Phone" class="form-label">Telefon</label>
            <input asp-for="Phone" type="tel" class="form-control" required pattern="[0-9]{10}" />
            <span asp-validation-for="Phone" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password" class="form-label">Şifre</label>
            <input asp-for="Password" type="password" class="form-control" required minlength="6" />
            <span asp-validation-for="Password" class="validation-error"></span>
        </div>

        <div class="form-group">
            <button type="submit" class="btn-register">Kayıt Ol</button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/Account/Register.js"></script>
}
